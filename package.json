{
  "name": "@mariovagomarzal/palette",
  "version": "0.1.0",
  "description": "Mario's color palette",
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit"
  },
  "author": "Mario Vago Marzal",
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.9.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
