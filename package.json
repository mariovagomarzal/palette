{
  "name": "@mariovagomarzal/palette",
  "version": "0.1.1",
  "description": "Mario's color palette",
  "scripts": {
    "build": "tsc && node scripts/build.ts",
    "check": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "author": "Mario Vago Marzal",
  "license": "MIT",
  "repository": "github:mariovagomarzal/palette",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.9.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./shiki": {
      "types": "./dist/ports/shiki.d.ts",
      "default": "./dist/ports/shiki.js"
    },
    "./palette.css": "./dist/palette.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@shikijs/types": "^4.3.1",
    "typescript": "^5.9.3"
  }
}
